rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'xp', 'createdAt', 'updatedAt']) 
          && data.keys().size() <= 7
          && data.uid == request.auth.uid
          && data.email is string && data.email.size() <= 200
          && data.xp is number && data.xp >= 0
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
      }

      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt
        && incoming().uid == existing().uid
        && (
          // Action: Daily XP Update
          incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'updatedAt']) ||
          // Action: Profile Update
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt'])
        );
        
      // --- Lab Progress (Subcollection) ---
      match /progress/{labId} {
        function isValidProgress(data) {
          return data.keys().hasAll(['labId', 'userId', 'completed', 'score', 'lastAttemptAt', 'updatedAt'])
            && data.keys().size() == 6
            && data.labId == labId
            && data.userId == request.auth.uid
            && data.completed is bool
            && data.score is number && data.score >= 0
            && data.lastAttemptAt is timestamp
            && data.updatedAt is timestamp;
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        
        allow create: if isOwner(userId) 
          && isValidId(labId)
          && isValidProgress(incoming())
          && incoming().updatedAt == request.time
          && incoming().lastAttemptAt == request.time;
          
        allow update: if isOwner(userId)
          && isValidId(labId)
          && isValidProgress(incoming())
          && incoming().updatedAt == request.time
          && incoming().userId == existing().userId
          && incoming().labId == existing().labId
          && incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'score', 'lastAttemptAt', 'updatedAt']);
      }

      // --- Lab Configs (Subcollection) ---
      match /labConfigs/{labType} {
        function isValidLabConfig(data) {
          let common = data.keys().hasAll(['updatedAt']) && data.updatedAt is timestamp;
          
          let isMech = labType == 'mechanical' 
            && data.keys().hasAll(['materialId', 'cuttingSpeed', 'feedRate'])
            && data.materialId is string && data.materialId.size() <= 64
            && data.cuttingSpeed is number && data.feedRate is number;
            
          let isBridge = labType == 'bridge'
            && data.keys().hasAll(['deadLoad', 'superDeadLoad', 'hydrostaticLoad', 'gammaD', 'gammaSD', 'materialId'])
            && data.deadLoad is number && data.superDeadLoad is number && data.hydrostaticLoad is number
            && data.gammaD is number && data.gammaSD is number && data.materialId is string;

          return common && (isMech || isBridge) && data.keys().size() <= 12;
        }

        allow get: if isOwner(userId);
        
        allow create, update: if isOwner(userId)
          && isValidId(labType)
          && isValidLabConfig(incoming())
          && incoming().updatedAt == request.time;
      }
    }
  }
}
